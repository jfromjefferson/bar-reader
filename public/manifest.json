{
  "manifest_version": 3,
  "name": "Bar Reader - Barcode & QR Scanner",
  "version": "1.0.0",
  "description": "Instantly scan barcodes and QR codes by selecting any area on your screen. Results are copied to clipboard and saved to history.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["clipboardWrite", "clipboardRead", "tabs", "activeTab", "scripting", "storage"]
}
